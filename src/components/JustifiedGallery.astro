---
interface Photo {
  src: string;
  w: number;
  h: number;
  slug?: string;
  seriesSlug?: string;
  title?: string;
}

interface Props {
  photos: Photo[];
  shuffle?: boolean;
  linkMode?: 'artwork' | 'series' | 'lightbox';
  targetHeight?: number;
}

const { photos, shuffle = false, linkMode = 'artwork', targetHeight = 130 } = Astro.props;
const id = 'gallery-' + Math.random().toString(36).slice(2, 8);
---

<div
  class="gallery-wrapper"
  id={id}
  data-shuffle={String(shuffle)}
  data-link-mode={linkMode}
  data-target={targetHeight}
>
  <div class="gallery-inner" data-photos={JSON.stringify(photos)}></div>
</div>

<script is:inline>
(function(){
  var GAP=12;

  function shuffle(a){var b=[].concat(a);for(var i=b.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=b[i];b[i]=b[j];b[j]=t}return b}

  function size(p,target){var r=p.w/p.h;return r>1?{w:target,h:Math.round(target/r)}:{w:Math.round(target*r),h:target}}

  function build(photos,cw,doShuffle,target){
    var items=doShuffle?shuffle(photos):[].concat(photos);
    var rows=[],cur=[],cwid=0;
    for(var i=0;i<items.length;i++){
      var p=items[i],s=size(p,target);
      var need=cwid+s.w+(cur.length>0?GAP:0);
      if(need<=cw||cur.length===0){cur.push({src:p.src,w:p.w,h:p.h,dispW:s.w,dispH:s.h,slug:p.slug,seriesSlug:p.seriesSlug,title:p.title,fullSrc:p.fullSrc});cwid=need}
      else{
        var tg=(cur.length-1)*GAP,scale=(cw-tg)/(cwid-tg);
        rows.push({photos:cur.map(function(x){return{src:x.src,w:x.w,h:x.h,dispW:Math.round(x.dispW*scale),dispH:Math.round(x.dispH*scale),slug:x.slug,seriesSlug:x.seriesSlug,title:x.title,fullSrc:x.fullSrc}}),height:Math.round(target*scale)});
        cur=[{src:p.src,w:p.w,h:p.h,dispW:s.w,dispH:s.h,slug:p.slug,seriesSlug:p.seriesSlug,title:p.title,fullSrc:p.fullSrc}];cwid=s.w
      }
    }
    if(cur.length)rows.push({photos:cur,height:target});
    return rows
  }

  // ---- lightbox ----
  var lbOverlay=null,lbImg=null,lbCounter=null,lbPhotos=[],lbIdx=0;

  function openLightbox(photos,idx){
    lbPhotos=photos;lbIdx=idx;
    if(!lbOverlay){
      lbOverlay=document.createElement('div');lbOverlay.className='lb-overlay';
      lbOverlay.innerHTML='<button class="lb-close">&times;</button><button class="lb-prev">&larr;</button><img class="lb-img" src="" alt=""><button class="lb-next">&rarr;</button><div class="lb-counter"></div>';
      document.body.appendChild(lbOverlay);
      lbImg=lbOverlay.querySelector('.lb-img');
      lbCounter=lbOverlay.querySelector('.lb-counter');
      lbOverlay.querySelector('.lb-close').addEventListener('click',closeLightbox);
      lbOverlay.querySelector('.lb-prev').addEventListener('click',function(e){e.stopPropagation();prevLightbox()});
      lbOverlay.querySelector('.lb-next').addEventListener('click',function(e){e.stopPropagation();nextLightbox()});
      lbOverlay.addEventListener('click',function(e){if(e.target===lbOverlay)closeLightbox()});
      document.addEventListener('keydown',function(e){
        if(!lbOverlay||lbOverlay.style.display!=='flex')return;
        if(e.key==='Escape')closeLightbox();
        if(e.key==='ArrowLeft')prevLightbox();
        if(e.key==='ArrowRight')nextLightbox();
      });
    }
    lbOverlay.style.display='flex';showCurrent();document.body.style.overflow='hidden'
  }

  function closeLightbox(){if(lbOverlay){lbOverlay.style.display='none';document.body.style.overflow=''}}

  function showCurrent(){if(lbImg&&lbPhotos[lbIdx]){lbImg.src=lbPhotos[lbIdx].fullSrc||lbPhotos[lbIdx].src;lbCounter.textContent=(lbIdx+1)+' / '+lbPhotos.length;if(lbPhotos[lbIdx].title)lbCounter.textContent=lbPhotos[lbIdx].title+' — '+lbCounter.textContent}}

  function prevLightbox(){if(lbPhotos.length){lbIdx=(lbIdx-1+lbPhotos.length)%lbPhotos.length;showCurrent()}}

  function nextLightbox(){if(lbPhotos.length){lbIdx=(lbIdx+1)%lbPhotos.length;showCurrent()}}

  // ---- render ----
  function render(el){
    var inner=el.querySelector('.gallery-inner');if(!inner)return;
    var raw=inner.dataset.photos;if(!raw)return;
    try{
      var allPhotos=JSON.parse(raw);
      var doShuffle=el.dataset.shuffle==='true';
      var linkMode=el.dataset.linkMode||'artwork';
      var baseTarget=parseInt(el.dataset.target)||130;
      var w=el.clientWidth;
      var target=w<600?Math.round(baseTarget*0.65):baseTarget;
      if(target<70)target=70;
      var rows=build(allPhotos,w,doShuffle,target);
      inner.style.opacity='0';
      inner.innerHTML='';
      var flatLightbox=linkMode==='lightbox'?[]:null;
      var flatIdx=0;
      for(var ri=0;ri<rows.length;ri++){
        var row=rows[ri],div=document.createElement('div');
        div.style.cssText='display:flex;gap:'+GAP+'px;margin-bottom:'+GAP+'px;align-items:center';
        for(var pi=0;pi<row.photos.length;pi++){
          var p=row.photos[pi];
          var img=document.createElement('img');img.src=p.src;img.width=p.dispW;img.height=p.dispH;img.alt='';img.loading='lazy';
          if(linkMode==='lightbox'){
            if(flatLightbox)flatLightbox.push(p);
            (function(idx){img.addEventListener('click',function(){openLightbox(flatLightbox||[p],idx)})})(flatIdx++);
            img.style.cursor='zoom-in';
            div.appendChild(img)
          }else if(linkMode==='series'&&p.seriesSlug){
            var a=document.createElement('a');a.href='/series/'+encodeURIComponent(p.seriesSlug)+'/';a.style.cssText='display:block;flex-shrink:0';a.appendChild(img);div.appendChild(a)
          }else if(p.slug){
            var a2=document.createElement('a');a2.href='/artwork/'+p.slug+'/';a2.style.cssText='display:block;flex-shrink:0';a2.appendChild(img);div.appendChild(a2)
          }else{
            div.appendChild(img)
          }
        }
        inner.appendChild(div)
      }
      inner.style.opacity='1'
    }catch(e){}
  }

  document.querySelectorAll('.gallery-wrapper').forEach(function(el){
    render(el);
    new ResizeObserver(function(){render(el)}).observe(el);
    window.addEventListener('resize',function(){render(el)})
  })
})();
</script>

<style>
  .gallery-wrapper { width: 100%; }
  .gallery-inner { line-height: 0; transition: opacity 0.15s; }
  .gallery-inner img { display: block; flex-shrink: 0; transition: opacity 0.2s; }
  .gallery-inner img:hover { opacity: 0.8; }
</style>

<style is:global>
  .lb-overlay {
    display: none; position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,0.92); align-items: center; justify-content: center;
    flex-direction: column;
  }
  .lb-overlay .lb-img { max-width: 90vw; max-height: 85vh; object-fit: contain; user-select: none; }
  .lb-overlay .lb-close { position: absolute; top: 20px; right: 28px; font-size: 32px; color: #aaa; background: none; border: none; cursor: pointer; line-height: 1; }
  .lb-overlay .lb-close:hover { color: #fff; }
  .lb-overlay .lb-prev, .lb-overlay .lb-next { position: absolute; top: 50%; transform: translateY(-50%); font-size: 24px; color: #aaa; background: none; border: none; cursor: pointer; padding: 20px 12px; line-height: 1; }
  .lb-overlay .lb-prev:hover, .lb-overlay .lb-next:hover { color: #fff; }
  .lb-overlay .lb-prev { left: 12px; }
  .lb-overlay .lb-next { right: 12px; }
  .lb-overlay .lb-counter { position: absolute; bottom: 28px; color: #999; font-size: 13px; font-family: inherit; }
</style>
