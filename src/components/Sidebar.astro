---
const nav = [
  { label: 'Works', href: '/series/' },
  { label: 'Events', href: '/events/' },
  { label: 'About', href: '/about/' },
];
const artist = 'Xiao Yu';
---

<aside class="sidebar">
  <a href="/" class="artist-name">{artist}</a>
  <nav>
    {nav.map(item => (
      <a
        href={item.href}
        class:list={["nav-link", { active: Astro.url.pathname.startsWith(item.href) }]}
      >
        {item.label}
      </a>
    ))}
  </nav>
</aside>

<style>
  .sidebar {
    width: var(--sidebar-width);
    padding: var(--content-padding) 24px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .artist-name {
    font-size: 15px;
    font-weight: 400;
    color: #111;
    margin-bottom: 28px;
    letter-spacing: 0.02em;
    display: block;
  }
  .artist-name:hover { opacity: 0.7; }
  .nav-link {
    font-size: 13px;
    font-weight: 200;
    color: var(--text-muted);
    padding: 3px 0;
    display: block;
    transition: color 0.2s;
  }
  .nav-link:hover, .nav-link.active {
    color: #111;
  }
  @media (max-width: 600px) {
    .sidebar {
      width: 100%;
      flex-direction: row;
      align-items: baseline;
      gap: 16px;
      padding: 16px 20px;
      flex-wrap: wrap;
    }
    .artist-name {
      margin-bottom: 0;
      margin-right: auto;
    }
    nav {
      display: flex;
      gap: 16px;
    }
  }
</style>
