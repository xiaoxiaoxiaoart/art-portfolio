---
const nav = [
  { label: '系列', href: '/series/' },
  { label: '事件', href: '/events/' },
  { label: '關於', href: '/about/' },
];
---

<aside class="sidebar">
  <a href="/" class="artist-name">
    <span class="name-en">xiao</span>
    <span class="name-cn">蕭愚</span>
  </a>
  <nav>
    {nav.map(item => (
      <a
        href={item.href}
        class:list={["nav-link", { active: Astro.url.pathname.startsWith(item.href) }]}
      >
        {item.label}
      </a>
    ))}
  </nav>
</aside>

<style>
  .sidebar {
    width: var(--sidebar-width);
    padding: var(--content-padding) 24px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .artist-name {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 28px;
    line-height: 1.3;
  }
  .name-en {
    font-size: 30px;
    color: #111;
    letter-spacing: 0;
    font-style: normal;
  }
  .name-cn {
    font-size: 30px;
    color: #111;
    letter-spacing: 0;
    font-style: normal;
  }
  .artist-name:hover { opacity: 0.7; }
  .nav-link {
    font-size: 26px;
    color: var(--text-muted);
    padding: 3px 0;
    display: block;
    transition: color 0.2s;
  }
  .nav-link:hover, .nav-link.active {
    color: #111;
  }
  @media (max-width: 600px) {
    .sidebar {
      width: 100%;
      flex-direction: row;
      align-items: baseline;
      gap: 16px;
      padding: 16px 20px;
      flex-wrap: wrap;
    }
    .artist-name {
      margin-bottom: 0;
      margin-right: auto;
      flex-direction: row;
      gap: 6px;
    }
    nav {
      display: flex;
      gap: 16px;
    }
  }
</style>
