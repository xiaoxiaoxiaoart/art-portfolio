---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
allEvents.sort((a, b) => b.data.date_start.getTime() - a.data.date_start.getTime());

function groupByYear(events: typeof allEvents) {
  const map: Record<number, typeof allEvents> = {};
  for (const e of events) {
    const y = e.data.date_start.getFullYear();
    (map[y] ??= []).push(e);
  }
  return map;
}

const performances = allEvents.filter(e => e.data.type === 'performance');
const exhibitions = allEvents.filter(e => e.data.type === 'exhibition');

const pByYear = groupByYear(performances);
const eByYear = groupByYear(exhibitions);

function ymEn(d: Date) {
  const m = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.getMonth()];
  return `${m} ${d.getFullYear()}`;
}
---

<BaseLayout title="事件">
  <div class="events-page">

    {exhibitions.length > 0 && (
      <section class="type-section">
        <h2 class="type-heading">展覽 Exhibitions</h2>
        {Object.entries(eByYear).sort(([a], [b]) => Number(b) - Number(a)).map(([year, evts]) => (
          <div class="year-group">
            <div class="year-label">{year}</div>
            {evts.map(e => (
              <div class="event-item">
                {e.data.title} / {e.data.title_en || e.data.title}
                <span class="meta"> &mdash; {e.data.venue_en || e.data.venue}, {e.data.city_en || e.data.city}, {ymEn(e.data.date_start)}</span>
              </div>
            ))}
          </div>
        ))}
      </section>
    )}

    {performances.length > 0 && (
      <section class="type-section">
        <h2 class="type-heading">演出 Performances</h2>
        {Object.entries(pByYear).sort(([a], [b]) => Number(b) - Number(a)).map(([year, evts]) => (
          <div class="year-group">
            <div class="year-label">{year}</div>
            {evts.map(e => {
              const lineupParts = (e.data.detail_content || '').split(' / ');
              const lineupEn = lineupParts.slice(1).join(' / ') || lineupParts[0] || '';
              return (
              <div class="event-block">
                <div class="event-item">
                  {e.data.title} / {e.data.title_en || e.data.title}
                  <span class="meta"> &mdash; {e.data.city_en || e.data.city}, {ymEn(e.data.date_start)}</span>
                </div>
                {lineupEn && (
                  <div class="event-lineup">{lineupEn}</div>
                )}
              </div>
            )})}
          </div>
        ))}
      </section>
    )}

    {allEvents.length === 0 && (
      <p class="empty">暫無事件</p>
    )}
  </div>
</BaseLayout>

<style>
  .events-page {
    max-width: 700px;
  }
  .type-section {
    margin-bottom: 48px;
  }
  .type-heading {
    font-size: 16px; font-weight: 400; color: #111;
    margin-bottom: 18px; letter-spacing: 0.03em;
  }
  .year-group {
    margin-bottom: 22px;
  }
  .year-label {
    font-size: 13px; color: #aaa;
    margin-bottom: 8px; letter-spacing: 0.05em;
  }
  .event-block {
    margin-bottom: 12px;
  }
  .event-item {
    font-size: 13px;
    line-height: 1.7;
    padding: 2px 0;
    color: var(--text-secondary);
  }
  .event-lineup {
    font-size: 12px;
    line-height: 1.6;
    color: var(--text-muted);
    padding-left: 0;
  }
  .meta {
    color: var(--text-muted);
  }
  .empty {
    font-size: 13px; color: var(--text-muted);
  }
</style>
