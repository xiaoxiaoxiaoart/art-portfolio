---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';

const allEvents = await getCollection('events');
allEvents.sort((a, b) => b.data.date_start.getTime() - a.data.date_start.getTime());

function groupByYear(events: typeof allEvents) {
  const map: Record<number, typeof allEvents> = {};
  for (const e of events) {
    const y = e.data.date_start.getFullYear();
    (map[y] ??= []).push(e);
  }
  return map;
}

const performances = allEvents.filter(e => e.data.type === 'performance');
const exhibitions = allEvents.filter(e => e.data.type === 'exhibition');

const pByYear = groupByYear(performances);
const eByYear = groupByYear(exhibitions);

function ymEn(d: Date) {
  const m = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.getMonth()];
  return `${m} ${d.getFullYear()}`;
}

const eventsWithPreviews = await Promise.all(
  allEvents.map(async (e) => {
    if (!e.data.preview_image) return { slug: e.slug, previewSrc: '' };
    const img = await getImage({ src: e.data.preview_image, width: 500 });
    return { slug: e.slug, previewSrc: img.src };
  })
);
const previewMap = new Map(eventsWithPreviews.map(e => [e.slug, e.previewSrc]));
---

<BaseLayout title="事件">
  <div class="events-page">
    <div class="events-list">

    {performances.length > 0 && (
      <section class="type-section">
        <h2 class="type-heading">演出 Performances</h2>
        {Object.entries(pByYear).sort(([a], [b]) => Number(b) - Number(a)).map(([year, evts]) => (
          <div class="year-group">
            <div class="year-label">{year}</div>
            {evts.map(e => {
              const lineupParts = (e.data.detail_content || '').split(' / ');
              const lineupEn = lineupParts.slice(1).join(' / ') || lineupParts[0] || '';
              const previewSrc = previewMap.get(e.slug) || '';
              return (
              <div class="event-block">
                <div
                  class:list={["event-item", { "has-preview": !!previewSrc }]}
                  data-event-preview={previewSrc}
                >
                  {e.data.title} / {e.data.title_en || e.data.title}
                  <span class="meta"> &mdash; {e.data.city_en || e.data.city}, {ymEn(e.data.date_start)}</span>
                </div>
                {lineupEn && (
                  <div class="event-lineup">{lineupEn}</div>
                )}
              </div>
            )})}
          </div>
        ))}
      </section>
    )}

    {exhibitions.length > 0 && (
      <section class="type-section">
        <h2 class="type-heading">展覽 Exhibitions</h2>
        {Object.entries(eByYear).sort(([a], [b]) => Number(b) - Number(a)).map(([year, evts]) => (
          <div class="year-group">
            <div class="year-label">{year}</div>
            {evts.map(e => {
              const previewSrc = previewMap.get(e.slug) || '';
              return (
              <div
                class:list={["event-item", { "has-preview": !!previewSrc }]}
                data-event-preview={previewSrc}
              >
                {e.data.title} / {e.data.title_en || e.data.title}
                <span class="meta"> &mdash; {e.data.venue_en || e.data.venue}, {e.data.city_en || e.data.city}, {ymEn(e.data.date_start)}</span>
              </div>
            )})}
          </div>
        ))}
      </section>
    )}

    {allEvents.length === 0 && (
      <p class="empty">暫無事件</p>
    )}
    </div>
    <div class="preview-panel"></div>
  </div>
</BaseLayout>

<script>
  import { initEventPreviews } from '../../scripts/events';
  initEventPreviews();
</script>

<style>
  .events-page { display: flex; gap: 40px; }
  .events-list { flex: 1; max-width: 700px; }
  .type-section { margin-bottom: 48px; }
  .type-heading {
    font-size: 16px; font-weight: 400; color: #111;
    margin-bottom: 18px; letter-spacing: 0.03em;
  }
  .year-group { margin-bottom: 22px; }
  .year-label {
    font-size: 13px; color: #aaa;
    margin-bottom: 8px; letter-spacing: 0.05em;
  }
  .event-block { margin-bottom: 12px; }
  .event-item {
    font-size: 13px; line-height: 1.7; padding: 2px 0;
    color: var(--text-secondary); transition: color 0.15s;
  }
  .event-item.has-preview { cursor: pointer; }
  .event-item.has-preview:hover { color: #111; text-decoration: underline; }
  .event-lineup {
    font-size: 12px; line-height: 1.6; color: var(--text-muted);
  }
  .meta { color: var(--text-muted); }
  .empty { font-size: 13px; color: var(--text-muted); }
  .preview-panel { width: 340px; flex-shrink: 0; position: relative; }
  .preview-panel img {
    max-width: 100%; max-height: 380px; display: block;
    position: absolute; opacity: 0; transition: opacity 0.2s;
  }
  @media (max-width: 800px) {
    .preview-panel { display: none; }
    .events-list { max-width: none; }
  }
</style>
