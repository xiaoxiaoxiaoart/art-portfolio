---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return works.map(w => ({ params: { slug: w.slug } }));
}

const { slug } = Astro.params;
const allWorks = await getCollection('works');
const work = allWorks.find(w => w.slug === slug);
if (!work) throw new Error(`找不到作品: ${slug}`);

const { title, year, medium, dimensions, description, series: seriesSlug, images } = work.data;

const optimizedImages = await Promise.all(
  images.map(img => getImage({ src: img, width: 1400 }))
);

const seriesWorks = allWorks
  .filter(w => w.data.series === seriesSlug)
  .sort((a, b) => a.data.order - b.data.order);

const currentIdx = seriesWorks.findIndex(w => w.slug === slug);
const prev = currentIdx > 0 ? seriesWorks[currentIdx - 1] : null;
const next = currentIdx < seriesWorks.length - 1 ? seriesWorks[currentIdx + 1] : null;
---

<BaseLayout title={title}>
  <div class="artwork">
    <div class="images">
      {optimizedImages.map((img, i) => (
        <img
          src={img.src}
          alt={`${title} — 圖像 ${i + 1}`}
          loading={i === 0 ? 'eager' : 'lazy'}
          class="artwork-img"
        />
      ))}
    </div>

    <div class="meta">
      <h1 class="title">{title}</h1>
      {year && <span class="field">{year}</span>}
      {medium && <span class="field">{medium}</span>}
      {dimensions && <span class="field">{dimensions}</span>}
      {description && <p class="desc">{description}</p>}
    </div>

    <nav class="artwork-nav">
      {prev ? <a href={`/artwork/${prev.slug}/`}>&larr; 上一張</a> : <span />}
      <a href={`/series/${seriesSlug}/`}>系列全部</a>
      {next ? <a href={`/artwork/${next.slug}/`}>下一張 &rarr;</a> : <span />}
    </nav>
  </div>
</BaseLayout>

<style>
  .artwork { max-width: 1000px; }
  .images { margin-bottom: 24px; }
  .artwork-img { width: 100%; height: auto; margin-bottom: 8px; }
  .meta { font-size: 14px; color: var(--text-secondary); line-height: 1.8; }
  .title { font-size: 16px; font-weight: 400; color: #111; margin-bottom: 8px; }
  .field { display: block; }
  .desc { margin-top: 16px; max-width: 500px; line-height: 1.7; }
  .artwork-nav {
    display: flex; justify-content: space-between;
    margin-top: 40px; font-size: 13px;
  }
  .artwork-nav a { color: var(--text-muted); }
  .artwork-nav a:hover { color: #111; }
</style>
