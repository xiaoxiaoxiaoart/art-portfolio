---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JustifiedGallery from '../../components/JustifiedGallery.astro';
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';

export async function getStaticPaths() {
  const series = await getCollection('series');
  return series.map(s => ({ params: { slug: s.slug } }));
}

function splitTitle(title: string) {
  const idx = title.search(/[A-Z]/);
  if (idx < 0) return { cn: title, en: '' };
  return { cn: title.slice(0, idx).trim(), en: title.slice(idx).trim() };
}

const { slug } = Astro.params;
const allSeries = await getCollection('series');
const currentSeries = allSeries.find(s => s.slug === slug);
if (!currentSeries) throw new Error(`找不到系列: ${slug}`);

const titleParts = splitTitle(currentSeries.data.title);
const descRaw = currentSeries.data.description || '';
const descParts = descRaw.split(/\n\n+/);
const descCn = descParts[0] || '';
const descEn = descParts.slice(1).join('\n\n') || '';

const allWorks = await getCollection('works');
const seriesWorks = allWorks
  .filter(w => w.data.series === slug)
  .sort((a, b) => a.data.order - b.data.order);

const photos = await Promise.all(
  seriesWorks.map(async (w) => {
    const img = w.data.images[0];
    const [thumb, full] = await Promise.all([
      getImage({ src: img, width: 1200 }),
      getImage({ src: img, width: 2400 })
    ]);
    return {
      src: thumb.src,
      fullSrc: full.src,
      w: img.width,
      h: img.height,
      title: w.data.title
    };
  })
);
---

<BaseLayout title={currentSeries.data.title}>
  <h2 class="series-title">
    <span class="title-cn">{titleParts.cn}</span>
    {titleParts.en && <span class="title-en">{titleParts.en}</span>}
  </h2>
  {descCn && (
    <div class="series-desc">
      <div class="desc-cn">{descCn}</div>
      {descEn && <div class="desc-en">{descEn}</div>}
    </div>
  )}
  <JustifiedGallery photos={photos} shuffle={false} linkMode="lightbox" targetHeight={230} />
  <a href="/series/" class="back-link">&larr; 全部作品</a>
</BaseLayout>

<style>
  .series-title {
    margin-bottom: 8px;
  }
  .title-cn {
    display: block;
    font-size: 18px;
    font-weight: 400;
    color: #111;
  }
  .title-en {
    display: block;
    font-size: 14px;
    color: var(--text-muted);
    margin-top: 2px;
  }
  .series-desc {
    margin-bottom: 28px;
    font-size: 13px;
    line-height: 1.7;
    color: #666;
  }
  .desc-cn {
    margin-bottom: 20px;
  }
  .desc-en {
  }
  .back-link {
    display: inline-block;
    margin-top: 32px;
    font-size: 13px;
    color: var(--text-muted);
  }
  .back-link:hover { color: #111; }
</style>
